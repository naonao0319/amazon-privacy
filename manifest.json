{
  "manifest_version": 3,
  "name": "Amazon プライバシーガード",
  "version": "1.4.0",
  "description": "Amazonサイト上の住所・名前・メール・電話番号・カード情報などの個人情報にモザイクをかけて保護します",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.co.jp/*",
        "https://www.amazon.com/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.com.au/*",
        "https://www.amazon.in/*",
        "https://www.amazon.com.br/*",
        "https://www.amazon.sg/*"
      ],
      "css": ["content/content.css"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ]
}
